# Frontend environment — copy to .env.local and adjust
# API base URL (Django backend). Must end with /api or the app will append /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api
# Alias (same meaning) for some hosting templates:
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

# Railway: set NEXT_PUBLIC_API_BASE_URL (or NEXT_PUBLIC_API_URL) in the frontend service Variables
# before build — Next.js inlines these at build time. Point at your deployed Django /api base URL.
